{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tanker://schemas/architecture.schema.json",
  "title": "Tanker Architecture",
  "type": "object",
  "required": ["system", "components", "api_contracts", "data_model", "tech_decisions", "risks", "open_decisions"],
  "properties": {
    "system": {
      "type": "object",
      "required": ["name", "one_liner"],
      "properties": {
        "name": { "type": "string" },
        "one_liner": { "type": "string" }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "responsibility", "owner_surface", "verify"],
        "properties": {
          "id": { "type": "string", "pattern": "^C-\\d{2}$" },
          "name": { "type": "string" },
          "kind": { "enum": ["frontend", "backend", "data", "infra", "external"] },
          "responsibility": { "type": "string" },
          "owner_surface": { "enum": ["frontend", "backend", "data", "infra"] },
          "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^C-\\d{2}$" } },
          "verify": { "type": "string" }
        }
      }
    },
    "api_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "method", "path", "auth", "request_schema", "response_schema", "errors"],
        "properties": {
          "id": { "type": "string", "pattern": "^API-\\d{2}$" },
          "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string", "pattern": "^/" },
          "auth": { "type": "string" },
          "request_schema": { "type": "string" },
          "response_schema": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "when"],
              "properties": {
                "code": { "type": "integer" },
                "when": { "type": "string" }
              }
            }
          },
          "idempotency_key": { "type": "string" }
        }
      }
    },
    "data_model": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity", "columns"],
        "properties": {
          "entity": { "type": "string" },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "pk": { "type": "boolean" },
                "fk": { "type": "string" },
                "nullable": { "type": "boolean" }
              }
            }
          },
          "indexes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "cols"],
              "properties": {
                "name": { "type": "string" },
                "cols": { "type": "array", "items": { "type": "string" } },
                "unique": { "type": "boolean" }
              }
            }
          },
          "rls": { "type": "string" },
          "retention": { "type": "string" }
        }
      }
    },
    "tech_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "rejected", "why"],
        "properties": {
          "id": { "type": "string", "pattern": "^TD-\\d{2}$" },
          "decision": { "type": "string" },
          "rejected": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "why": { "type": "string", "minLength": 20 }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "risk", "mitigation", "severity"],
        "properties": {
          "id": { "type": "string", "pattern": "^R-\\d{2}$" },
          "risk": { "type": "string" },
          "mitigation": { "type": "string" },
          "severity": { "enum": ["P0", "P1", "P2"] }
        }
      }
    },
    "open_decisions": {
      "type": "array",
      "maxItems": 0,
      "description": "Must be empty. Resolve before producing architecture."
    }
  }
}
