{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tanker://schemas/plan.schema.json",
  "title": "Tanker Plan",
  "type": "object",
  "required": ["version", "feature", "total_est_minutes", "steps", "decisions", "risks", "open_questions"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "feature": { "type": "string" },
    "total_est_minutes": { "type": "integer", "minimum": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "verify", "est_minutes", "depends_on", "risk"],
        "properties": {
          "id": { "type": "string", "pattern": "^P-\\d{2}$" },
          "title": { "type": "string" },
          "subtasks": { "type": "array", "items": { "type": "string" } },
          "verify": { "type": "string", "minLength": 10 },
          "est_minutes": { "type": "integer", "minimum": 1, "maximum": 60 },
          "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^P-\\d{2}$" } },
          "risk": { "enum": ["P0", "P1", "P2"] },
          "files_touched": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "alternatives_rejected", "why"],
        "properties": {
          "id": { "type": "string", "pattern": "^D-\\d{2}$" },
          "decision": { "type": "string" },
          "alternatives_rejected": { "type": "array", "items": { "type": "string" } },
          "why": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "risk", "mitigation", "step_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^R-\\d{2}$" },
          "risk": { "type": "string" },
          "mitigation": { "type": "string" },
          "step_ids": { "type": "array", "items": { "type": "string", "pattern": "^P-\\d{2}$" } }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "maxItems": 0
    }
  }
}
